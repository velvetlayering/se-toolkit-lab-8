# See wiki/caddy.md

:{$CADDY_CONTAINER_PORT} {
    handle /items* {
        reverse_proxy http://backend:{$BACKEND_CONTAINER_PORT}
    }
    handle /learners* {
        reverse_proxy http://backend:{$BACKEND_CONTAINER_PORT}
    }
    handle /interactions* {
        reverse_proxy http://backend:{$BACKEND_CONTAINER_PORT}
    }
    handle /pipeline* {
        reverse_proxy http://backend:{$BACKEND_CONTAINER_PORT}
    }
    handle /analytics* {
        reverse_proxy http://backend:{$BACKEND_CONTAINER_PORT}
    }
    handle_path /utils/llm-api* {
        reverse_proxy {$LLM_API_BASE_URL}
    }
    handle /ws/chat {
        reverse_proxy http://nanobot:{$NANOBOT_WEBCHAT_CONTAINER_PORT}
    }
    handle_path /utils/pgadmin* {
        reverse_proxy http://pgadmin:{$CONST_PGADMIN_CONTAINER_PORT}
    }
    handle /docs* {
        reverse_proxy http://backend:{$BACKEND_CONTAINER_PORT}
    }
    handle /openapi.json {
        reverse_proxy http://backend:{$BACKEND_CONTAINER_PORT}
    }
    handle_path /flutter* {
        root * /srv/flutter
        try_files {path} /index.html
        file_server
    }
    handle {
        root * /srv/react
        try_files {path} /index.html
        file_server
    }
}
